POSTGRES_DB_HOST_NAME=127.0.0.1
POSTGRES_DB_NAME=postgres
POSTGRES_DB_PORT=5432
POSTGRES_DB_PASSWORD=p4ssw0rd
POSTGRES_DB_USER_NAME=postgres

# Offline inference (Web GUI reads artifacts; daemon/export write them)

# Path to trading_bot repo (policy/gate post-processing for trade research NPZ loader)
TRADING_BOT_ROOT=/home/debian/Repositories/trading_bot

# Background inference daemon (python3 -m main.inference_daemon)
INFERENCE_DAEMON_SYMBOL=BTC_USDT
INFERENCE_DAEMON_INTERVAL_SEC=60
INFERENCE_DAEMON_BARS_LIMIT=10000000

# Web GUI bars limit (default in toolbar; chart API loads min(limit, chart_x1_fetch_limit))
WEB_GUI_RECORDS_LIMIT=10000000

# Spawn pools: heavy=1 prevents parallel large DB loads; light allows COUNT alongside chart load
SPAWN_WORKER_HEAVY_POOL_SIZE=1
SPAWN_WORKER_LIGHT_POOL_SIZE=2
SPAWN_WORKER_JOURNAL_POOL_SIZE=1

# Web GUI x1 bars cache (shared across GUI / inference_daemon / trade_research_export)
WEB_GUI_BARS_REDIS_CACHE_ENABLED=true
BARS_REDIS_CACHE_TTL_SEC=60
BARS_REDIS_REFRESH_LOCK_TTL_SEC=600
BARS_REDIS_LOCK_WAIT_SEC=300
POLARS_MAX_THREADS=14

# inference_api must be running for daemon and trade research export
WEB_GUI_INFERENCE_ENABLED=true
WEB_GUI_INFERENCE_API_BASE_URL=http://127.0.0.1:8010

# Exit overlays are computed by the daemon into latest_inference.json
WEB_GUI_EXIT_GBM_ENABLED=false
WEB_GUI_EXIT_TRANSFORMER_ENABLED=false

# Micro live journal (one path per web_gui instance / operator)
WEB_GUI_TRADE_JOURNAL_PATH=data/trade_journal.json
# Match policy eval horizon when switching stacks (x2048 prod, x1536 paper)
WEB_GUI_TRADE_JOURNAL_DEFAULT_EVAL_HORIZON=x2048
